  "info": {
    "title": "llame API",
    "description": "llame auth and domain API",
    "version": "0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "opaque",
        "type": "http"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "llame_session"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "maxLength": 200
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "PublicUserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "object",
            "nullable": true
          },
          "email": {
            "type": "object",
            "nullable": true,
            "format": "email"
          },
          "emailVerified": {
            "type": "object",
            "nullable": true,
            "format": "date-time"
          },
          "image": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id"
        ]
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userAgent": {
            "type": "object",
            "nullable": true
          },
          "ip": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "lastSeenAt": {
            "format": "date-time",
            "type": "string"
          },
          "expires": {
            "format": "date-time",
            "type": "string"
          },
          "current": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "createdAt",
          "lastSeenAt",
          "expires",
          "current"
        ]
      },
      "AuthTokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Opaque bearer token. Stored server-side only as a SHA-256 hash."
          },
          "user": {
            "$ref": "#/components/schemas/PublicUserResponse"
          },
          "session": {
            "$ref": "#/components/schemas/SessionResponse"
          }
        },
        "required": [
          "token",
          "user",
          "session"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SessionsResponse": {
        "type": "object",
        "properties": {
          "sessions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionResponse"
            }
          }
        },
        "required": [
          "sessions"
        ]
      },
      "SessionRevocationResponse": {
        "type": "object",
        "properties": {
          "revokedCount": {
            "type": "number"
          }
        },
        "required": [
          "revokedCount"
        ]
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "ownerUserId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "private",
              "public"
            ]
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "ownerUserId",
          "title",
          "visibility",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateChatDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200
          }
        }
      },
      "UpdateChatTitleDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "required": [
          "title"
        ]
      }
    }
  }
}
