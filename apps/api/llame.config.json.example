// llame operator configuration (config-as-code).
//
// Optional — llame boots on documented built-in defaults when this file is
// absent (but chat needs defaults.modelId, so a real instance wants this
// file). Copy this example to `llame.config.json` (same directory by default,
// or wherever LLAME_CONFIG_PATH points):
//   cp apps/api/llame.config.json.example apps/api/llame.config.json
//
// Format: JSONC — // and /* */ comments and trailing commas are allowed.
// Validation: validated at boot against the published JSON Schema
// (src/instance-config/llame.config.schema.json, referenced below via
// $schema) — a strict, closed schema. Unknown keys and wrong types fail the
// boot loudly, naming the offending path; llame never serves on a partial or
// silently-defaulted config.
// There is no hot-reload — changes take effect on restart.
//
// Precedence per setting: file > built-in default. Bare environment variables
// are NOT a config source — the environment reaches these settings only via
// {env:NAME} interpolation tokens written in this file (as the entries below
// demonstrate). A key that is absent (or set to explicit `null`, for nullable
// settings) is simply unset and takes the built-in default.
//
// String values may interpolate:
//   {env:NAME}            the environment variable NAME (fails boot if unset)
//   {env:NAME:-default}   NAME, or "default" if NAME is unset OR empty
//                         (bash/compose `:-` style)
//   {path:LOCATION}       trimmed contents of the file at LOCATION (Docker/K8s
//                         file-mounted secrets), e.g. {path:/run/secrets/openai_key}
//   {{                    a literal "{" (double it to escape) — e.g. the string
//                         "prefix-{{" resolves to "prefix-{"
// Interpolation is single-pass: a resolved value is a literal and is never
// re-scanned for further tokens. Resolved values are never logged.
//
// providers[].key is the intended {path:...} use case, e.g.
// "key": "{path:/run/secrets/openai_key}" for a Docker/K8s file-mounted secret.
//
// Embedded (mid-string) tokens are only legal on string-typed settings, like
// "defaults.modelId" below. Number/boolean settings must use a WHOLE-VALUE,
// quoted token that gets coerced to the right type after resolution — never a
// bare number with an embedded token, and never an unquoted token. See the
// "runs" block below.
{
  "$schema": "./src/instance-config/llame.config.schema.json",

  // Instance-level model pointers — deliberately not under the "models" key
  // below, which holds the executable catalog itself. Each pointer must
  // reference a "models[].id" when set, or startup fails. The
  // {env:...:-default} tokens keep these drivable from the environment (see
  // apps/api/.env.example) while the file stays the single source of truth.
  "defaults": {
    "modelId": "{env:DEFAULT_MODEL_ID:-system:openai:gpt-5.4-mini}",
    "titleGenerationModelId": "{env:TITLE_GENERATION_MODEL_ID:-system:openai:gpt-5.4-nano}"
  },

  // Provider connections (providers-and-models-as-code, #167). Providers are
  // duplicable: two entries of the same "type" with distinct "id"s (and
  // typically distinct "baseUrl"s) coexist, e.g. hosted OpenAI alongside a
  // local Ollama. Only "type": "openai" is supported today (native OpenAI +
  // any OpenAI-compatible endpoint) — an Anthropic adapter is a follow-up.
  // "key" absent, null, or resolving empty means keyless (no credential sent
  // as a bare env var — OPENAI_API_KEY/OPENAI_BASE_URL are now interpolation
  // inputs referenced here, not settings read directly).
  "providers": [
    {
      "id": "openai",
      "type": "openai",
      "key": "{env:OPENAI_API_KEY:-}",
      "baseUrl": "{env:OPENAI_BASE_URL:-}"
    }
    // A second, keyless provider — e.g. a local Ollama — coexists by id:
    // {
    //   "id": "ollama",
    //   "type": "openai",
    //   "baseUrl": "{env:OLLAMA_BASE_URL:-http://localhost:11434/v1}"
    // }
  ],

  // The executable model catalog (providers-and-models-as-code, #167),
  // superseding the formerly hardcoded server catalog. Every entry's
  // "provider" must reference a "providers[].id" above, or startup fails.
  // "contextWindowTokens" is required and execution-critical — it sizes the
  // context-compaction trigger (x COMPACTION_WINDOW_RATIO) unless the
  // optional "compactionThresholdTokens" overrides it per model.
  "models": [
    {
      "id": "system:openai:gpt-5.5",
      "provider": "openai",
      "providerModelId": "gpt-5.5",
      "name": "GPT-5.5",
      "description": "Most capable system OpenAI-compatible model.",
      "contextWindowTokens": 400000,
      "pricingUsdPer1M": { "input": 2.5, "cachedInput": 0.25, "output": 10 },
      "reasoning": true,
      "website": "https://openai.com"
    },
    {
      "id": "system:openai:gpt-5.4",
      "provider": "openai",
      "providerModelId": "gpt-5.4",
      "name": "GPT-5.4",
      "description": "High-capability system OpenAI-compatible model.",
      "contextWindowTokens": 400000,
      "pricingUsdPer1M": { "input": 1.25, "cachedInput": 0.125, "output": 7.5 },
      "reasoning": true,
      "website": "https://openai.com"
    },
    {
      "id": "system:openai:gpt-5.4-mini",
      "provider": "openai",
      "providerModelId": "gpt-5.4-mini",
      "name": "GPT-5.4 Mini",
      "description": "Balanced default system OpenAI-compatible model.",
      "contextWindowTokens": 400000,
      "pricingUsdPer1M": { "input": 0.75, "cachedInput": 0.075, "output": 4.5 },
      "reasoning": true,
      "website": "https://openai.com",
      // Low override so the qa-evals overflow case (#58) triggers lineage
      // compaction within a handful of cheap turns against the default model.
      "compactionThresholdTokens": 300
    },
    {
      "id": "system:openai:gpt-5.4-nano",
      "provider": "openai",
      "providerModelId": "gpt-5.4-nano",
      "name": "GPT-5.4 Nano",
      "description": "Small system OpenAI-compatible model for internal work.",
      "contextWindowTokens": 400000,
      "pricingUsdPer1M": { "input": 0.1, "cachedInput": 0.01, "output": 0.4 },
      "website": "https://openai.com"
    },
    {
      "id": "system:openai:gpt-4o",
      "provider": "openai",
      "providerModelId": "gpt-4o",
      "name": "GPT-4o",
      "description": "Fast, intelligent, flexible GPT model.",
      "contextWindowTokens": 128000,
      "pricingUsdPer1M": { "input": 2.5, "output": 10 },
      "knowledgeCutoff": "2023-10-01",
      "website": "https://openai.com",
      "apiDocs": "https://platform.openai.com/docs/models/gpt-4o",
      "modelPage": "https://platform.openai.com/docs/models/gpt-4o",
      "releasedAt": "2024-08-06"
    },
    {
      "id": "system:openai:gpt-4o-mini",
      "provider": "openai",
      "providerModelId": "gpt-4o-mini",
      "name": "GPT-4o Mini",
      "contextWindowTokens": 128000,
      "pricingUsdPer1M": { "input": 0.15, "cachedInput": 0.075, "output": 0.6 },
      "website": "https://openai.com",
      "apiDocs": "https://platform.openai.com/docs/models/gpt-4o-mini",
      "modelPage": "https://platform.openai.com/docs/models/gpt-4o-mini"
    }
  ],

  // Run liveness (durable-run-workers D7). heartbeatSeconds/timeoutSeconds are
  // numbers, so an interpolated value on them must be a whole-value quoted
  // token — the resolved string is coerced to a number after resolution; a
  // non-numeric resolution fails the boot.
  "runs": {
    // Reserved for the future run-output-budget feature (#91) — the schema
    // accepts this key today, but nothing consumes it yet: setting it here
    // does NOT currently cap a run's output tokens.
    "maxOutputTokens": null,
    // The job-queue's native worker-liveness window: pg-boss fails+retries a
    // run's job if its worker stops auto-signalling liveness for this long
    // (>= 10s — pg-boss's own floor). Worker-death detection, not an
    // application heartbeat interval.
    "heartbeatSeconds": "{env:RUN_HEARTBEAT_SECONDS:-15}",
    // In-process wall-clock budget: a run exceeding this while its worker is
    // alive is aborted and recorded as run.expired.
    "timeoutSeconds": "{env:RUN_TIMEOUT_SECONDS:-300}"
  },

  "http": {
    // Reverse-proxy trust (#68). Nullable:
    //   - `null` (or key absent)   -> not behind a proxy; proxy headers untrusted
    //   - "{env:TRUST_PROXY:-}"    -> drivable from the TRUST_PROXY env var;
    //                                 resolves to empty = unset when the var
    //                                 is unset or blank
    //   - a hop count (e.g. "1") or an Express subnet spec -> literal setting
    "trustProxy": "{env:TRUST_PROXY:-}"
  },

  // Database connection pool (durable-run-workers). A run holds a connection
  // per runAs transaction, so set poolSize >= this process's total run
  // concurrency (sum of the active worker profile's group concurrencies) plus
  // HTTP headroom; poolSize x replicas must stay within Postgres
  // max_connections. Falls back to DB_POOL_SIZE, then 10.
  "db": {
    "poolSize": "{env:DB_POOL_SIZE:-10}"
  },

  // Tool-calling loop (openspec/changes/tool-calling-loop). The operator
  // allowlist is the ENTIRE availability story this slice (D3): remove the
  // block (or empty the list) to turn tools off — absent/empty = no tools
  // advertised or executable. All built-in tools are read-only over the
  // user's own data; nothing here reaches the network.
  "tools": {
    // Registered tool ids to allow. An id not registered in the code-owned
    // tool registry fails boot naming this path and the id.
    "allowed": ["search_conversations"],
    // Hard cap on tool-requesting steps per run before the loop stops
    // offering tools and drives the model to answer from what it has.
    "maxStepsPerRun": 8,
    // Per-tool-call timeout, in seconds (a tool may override at registration).
    "callTimeoutSeconds": 15
  },

  // Worker profiles (durable-run-workers D2/D4, docs/scaling.md): profile
  // name -> the fixed consumer groups ("runs", "search-reindex",
  // "sessions-cleanup") it consumes and each one's main-queue concurrency.
  // Selected at boot by LLAME_WORKER_PROFILE (default "all"); an unknown
  // group name or an LLAME_WORKER_PROFILE naming a profile absent here fails
  // boot loudly. Omit this block entirely to keep the built-in defaults:
  // "all" (every group at concurrency 1 — today's co-located behavior) and
  // "web" (no groups — an HTTP-only process, e.g. paired with a dedicated
  // `worker` running "all"). A file entry merges over a built-in profile
  // PER GROUP, so `"all": { "runs": 4 }` just raises runs concurrency and
  // keeps search-reindex/sessions-cleanup at 1 (it does NOT drop them); to
  // run a strict subset, declare a new profile name. Uncomment to declare
  // your own split, e.g. a future taint profile:
  // "workers": {
  //   "all": { "runs": 4 },
  //   "heavy": { "search-reindex": 2 }
  // }
}
