# apps/api environment — copy to .env.local for local dev:
#   cp apps/api/.env.example apps/api/.env.local
#
# Operator settings (model defaults, run timers, trust proxy) live in
# llame.config.json — the operator config-as-code file:
#   cp apps/api/llame.config.json.example apps/api/llame.config.json
# Bare env vars are NOT a config source for those settings; the environment
# reaches them only via {env:NAME} interpolation tokens inside the file (the
# committed example already references the variables below that way). The file
# is read from this directory by default, overridable via LLAME_CONFIG_PATH.
# Both this file and the config file are deploy-time — changes need a restart.
#
# Points at the docker-compose Postgres (repo-root compose.yaml) and connects as the
# non-superuser `app` role, so RLS/FORCE (the multi-tenant moat) is active in dev.
POSTGRES_URL=postgres://app:app@localhost:5432/llame

# Comma-separated browser origins allowed to call this api with credentials.
WEB_ORIGIN=http://localhost:3000

# Leave empty for localhost. Set to a shared parent domain in production, e.g. .example.com.
SESSION_COOKIE_DOMAIN=

# Model-provider key the chat worker uses when the configured endpoint needs one.
# Leave empty only for keyless OpenAI-compatible endpoints such as local dev servers.
OPENAI_API_KEY=

# Any OpenAI-compatible endpoint works (#88) — point dev and the eval suite at a
# cheap or free provider instead of paid OpenAI. Leave empty for api.openai.com.
# Model selection uses llame's opaque model ids, configured in llame.config.json.
# Example — OpenRouter free tier:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=<your OpenRouter key>
OPENAI_BASE_URL=

# Interpolation targets for llame.config.json's defaults.modelId /
# defaults.titleGenerationModelId — these take effect ONLY where the config
# file references them via {env:DEFAULT_MODEL_ID} / {env:TITLE_GENERATION_MODEL_ID}
# tokens (the committed example does, with sensible :- defaults).
DEFAULT_MODEL_ID=system:openai:gpt-5.4-mini
TITLE_GENERATION_MODEL_ID=system:openai:gpt-5.4-nano

# Context window of the configured model, in tokens (e.g. 128000, 1000000). Used to
# derive the conversation-compaction trigger (#57): compact at 80% of the window.
# Known models (src/models/model-catalog.ts) are derived automatically — set this only
# to override, or when running a model the catalog doesn't know (arbitrary
# OPENAI_BASE_URL endpoints). Empty + unknown model = conservative default (100000).
MODEL_CONTEXT_WINDOW_TOKENS=

# Explicit compaction trigger override, in tokens (#57): when the chat's live context
# (real usage of the last turn, estimated as a fallback) exceeds this, older turns are
# summarized into a lineage row and only the summary + recent turns are sent to the
# model. Takes precedence over the MODEL_CONTEXT_WINDOW_TOKENS derivation. Usually
# leave empty; the eval suite sets it very low to exercise compaction cheaply.
COMPACTION_TOKEN_THRESHOLD=

# Tool-calling loop availability/step-cap/timeout (openspec/changes/
# tool-calling-loop) are config-as-code, NOT env vars: set tools.allowed /
# tools.maxStepsPerRun / tools.callTimeoutSeconds in llame.config.json (see the
# commented "tools" block in llame.config.json.example). Default: no tools
# advertised or executable — an instance that doesn't configure the allowlist
# runs exactly as before this change. There is no env-var fallback for these
# (the operator allowlist must not be a user-mergeable config source).

# Run liveness (#48). A per-run deadman job fires RUN_TIMEOUT_SECONDS
# (default 300) after enqueue: a terminal run is left alone, a run with a fresh
# heartbeat is re-checked later, and a run whose heartbeat is older than
# runs.heartbeatStaleSeconds (default 60) is expired. The executing worker
# stamps the heartbeat every runs.heartbeatSeconds (default 15).
# Configure in llame.config.json (runs.*); these variables are interpolation
# targets only, usable via {env:...} tokens in the file.
RUN_HEARTBEAT_SECONDS=
RUN_HEARTBEAT_STALE_SECONDS=
RUN_TIMEOUT_SECONDS=

# Behind a reverse proxy, set http.trustProxy in llame.config.json to the hop
# count (e.g. 1) or an Express subnet spec so session.ip records the real
# client, not the proxy (#68). Leave unset when clients connect directly —
# trusting proxy headers with no proxy lets clients spoof their IP. This
# variable is an interpolation target only ({env:TRUST_PROXY} in the file).
TRUST_PROXY=
