# apps/api environment — copy to .env.local for local dev:
#   cp apps/api/.env.example apps/api/.env.local
#
# Points at the docker-compose Postgres (repo-root compose.yaml) and connects as the
# non-superuser `app` role, so RLS/FORCE (the multi-tenant moat) is active in dev.
POSTGRES_URL=postgres://app:app@localhost:5432/llame

# Comma-separated browser origins allowed to call this api with credentials.
WEB_ORIGIN=http://localhost:3000

# Leave empty for localhost. Set to a shared parent domain in production, e.g. .example.com.
SESSION_COOKIE_DOMAIN=

# Model-provider key the chat loop uses to generate replies. Instance-wide for v0.1
# (per-user BYOK is v0.4 — see #37). REQUIRED for chat: without it every
# POST /api/v1/chats/:id/messages returns 402 and no reply is produced.
OPENAI_API_KEY=

# Any OpenAI-compatible endpoint works (#88) — point dev and the eval suite at a
# cheap or free provider instead of paid OpenAI. Leave both empty for api.openai.com
# and its built-in default model. Example — OpenRouter free tier:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=openai/gpt-oss-20b:free
#   OPENAI_API_KEY=<your OpenRouter key>
OPENAI_BASE_URL=
OPENAI_MODEL=

# Context window of the configured model, in tokens (e.g. 128000, 1000000). Used to
# derive the conversation-compaction trigger (#57): compact at 80% of the window.
# Known models (src/models/model-catalog.ts) are derived automatically — set this only
# to override, or when running a model the catalog doesn't know (arbitrary
# OPENAI_BASE_URL endpoints). Empty + unknown model = conservative default (100000).
MODEL_CONTEXT_WINDOW_TOKENS=

# Explicit compaction trigger override, in tokens (#57): when the chat's live context
# (real usage of the last turn, estimated as a fallback) exceeds this, older turns are
# summarized into a lineage row and only the summary + recent turns are sent to the
# model. Takes precedence over the MODEL_CONTEXT_WINDOW_TOKENS derivation. Like the
# run budget below, this is the INSTANCE layer of the config resolver (#46) — scope
# config rows (org/user/chat) override it per resolution. Usually leave empty; the
# eval suite sets it very low to exercise compaction cheaply.
COMPACTION_TOKEN_THRESHOLD=

# Per-run output-token ceiling. This env value is the INSTANCE layer of the config
# resolver (#46) — org/user/chat scope config rows override it, and the effective
# value is snapshotted onto the run row at creation (runs.config_snapshot) alongside
# its provenance (which scope set it). Empty = no instance-level cap. Enforcement of
# the resolved value is a downstream concern of whichever run-execution slice reads
# the snapshot.
RUN_MAX_OUTPUT_TOKENS=

# Hard step cap for the tool-calling loop: the model may call a tool and get
# re-called at most this many times per turn before the loop is forced to stop
# (stopWhen: stepCountIs(N)) — a runaway that keeps calling tools cannot loop
# forever. Same INSTANCE layer / config-resolver-snapshot pattern as the other
# run.* settings above. Empty = the built-in default (4).
RUN_MAX_STEPS=

# CUMULATIVE token cap across the tool-calling loop's steps (#91). A multi-step
# run re-sends the growing context every step, so maxSteps × RUN_MAX_OUTPUT_TOKENS
# badly under-counts real spend — this bounds the run's actual token cost as a
# second stopWhen condition (the loop stops when EITHER cap fires). Same INSTANCE
# layer / config-resolver-snapshot pattern as the other run.* settings. Opt-in:
# empty = no cumulative cap, so no default can truncate a legitimately long run.
RUN_MAX_RUN_TOKENS=

# Instance-level, operator-only tool allowlist for the tool-calling loop (#45).
# Comma-separated built-in tool names, e.g. TOOLS_ENABLED=get_current_time,search_conversations
# Composes with the policy gate rather than bypassing it: it only upgrades a
# tool's verdict when no policy matched ('unset'), and only for a low/own-scope
# risk class (read_only/compute_only/search_only/write_local/write_internal) —
# a write_external/destructive tool can never be env-enabled, and an explicit
# policy deny always wins regardless of this env. Read directly from env, NEVER
# from the config resolver's user-mergeable snapshot — a user can write their
# own user-scope config row (configs_write RLS), so honoring a merged
# tools.enabled there would let a user self-grant. Empty = only the code-owned
# safe allowlist is available (today's shipped tools, get_current_time and
# search_conversations, are both already safe-listed, so this is currently a
# no-op — it's the control surface for the write-capable tools landing next).
TOOLS_ENABLED=

# Run liveness (#48). A per-run deadman job fires RUN_TIMEOUT_SECONDS
# (default 300) after enqueue: a terminal run is left alone, a run with a fresh
# heartbeat is re-checked later, and a run whose heartbeat is older than
# RUN_HEARTBEAT_STALE_SECONDS (default 60) is expired. The executing worker
# stamps the heartbeat every RUN_HEARTBEAT_SECONDS (default 15).
RUN_HEARTBEAT_SECONDS=
RUN_HEARTBEAT_STALE_SECONDS=
RUN_TIMEOUT_SECONDS=

# BYOK credential vault (#18): master key ring for encrypting user-supplied
# provider API keys at rest (AES-256-GCM, envelope per credential). Format:
#   CREDENTIAL_MASTER_KEYS=1:<base64 32 bytes>[,2:<base64 32 bytes>,...]
# Generate a key with: openssl rand -base64 32
# New secrets seal under the highest version; rotation = append a version and
# re-encrypt lazily (never remove a version that still has live rows).
# Empty = BYOK disabled: the instance still boots and the instance-wide
# OPENAI_API_KEY continues to work; provider-account creation returns 400.
CREDENTIAL_MASTER_KEYS=

# Behind a reverse proxy, set to the hop count (e.g. 1) or an Express subnet
# spec so session.ip records the real client, not the proxy (#68). Leave empty
# when clients connect directly — trusting proxy headers with no proxy lets
# clients spoof their IP.
TRUST_PROXY=
