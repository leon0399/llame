            "content": "import * as React from \"react\";\nimport type { Meta, StoryObj } from \"@storybook/nextjs-vite\";\nimport {\n  CalculatorIcon,\n  CalendarIcon,\n  CreditCardIcon,\n  SettingsIcon,\n  SmileIcon,\n  UserIcon,\n} from \"lucide-react\";\nimport { expect, screen, waitFor } from \"storybook/test\";\n\nimport { Button } from \"./button.js\";\nimport {\n  Command,\n  CommandDialog,\n  CommandEmpty,\n  CommandGroup,\n  CommandInput,\n  CommandItem,\n  CommandList,\n  CommandSeparator,\n  CommandShortcut,\n} from \"./command.js\";\n\n// Every story below is transcribed from the shadcn Command docs\n// (https://ui.shadcn.com/docs/components/radix/command), so the file carries\n// the \"shadcn-example\" provenance tag at the meta level. Source:\n// `apps/v4/examples/radix/command-<x>.tsx` on GitHub main, the files the\n// docs' \"Radix UI\" tab renders. RTL is skipped by convention.\n//\n// Naming: the docs page has a lead, unanchored preview (`command-demo`,\n// before any heading) AND a separately anchored \"## Basic\" example\n// (`command-basic.tsx`) — same collision shape as collapsible-demo /\n// collapsible-basic. Here the lead demo takes `Basic` (matching the\n// select/avatar/collapsible precedent for a page's lead example, linked to\n// the base docs page with no anchor).\n//\n// Two upstream examples are intentionally NOT their own story:\n// - `command-basic.tsx` (mdx \"## Basic\"): a Button-triggered CommandDialog\n//   around a single plain \"Suggestions\" group (no icons, no shortcuts) — a\n//   strict content subset of `AsDialog` below (same dialog composition,\n//   richer content) with no incremental concept to teach, so it's dropped\n//   rather than invent a sixth name outside the requested set.\n// - `command-groups.tsx` (mdx \"## Groups\"): renders the exact same two\n//   groups/items as the lead `command-demo` (Suggestions + Settings, icons,\n//   separator, shortcuts), differing only in whether the Calculator item is\n//   `disabled` — effectively identical to `Basic`, so it's collapsed into it\n//   rather than kept as a near-duplicate story (same treatment as the\n//   accordion-demo/accordion-basic collapse noted in collapsible.stories.tsx).\n//\n// `Shortcuts` and `Scrollable` are rendered as an inline `Command` panel\n// rather than their upstream Button+CommandDialog wrapper: Command's own\n// primary form is the inline panel (only `AsDialog` demonstrates the overlay\n// composition), and dropping the wrapper here also avoids nesting a second\n// `<Command>` inside `<CommandDialog>` — our `CommandDialog` already supplies\n// the `Command` root (see command.tsx), so the upstream examples' own extra\n// `<Command>` around their children would double-wrap it.\n//\n// `AsDialog` (`command-dialog.tsx`) is adapted from a global `⌘J` keydown\n// listener + `<kbd>` hint to a `Button` trigger: it isn't referenced by name\n// from the current command.mdx (no anchor to link), but is a registered\n// shadcn example (`apps/v4/registry.json` → \"command-dialog\"). A persistent\n// `document`-level keydown listener is unnecessary Storybook plumbing and\n// makes the trigger untestable without simulating a platform-specific\n// meta/ctrl chord — a `Button` matches how every other dialog-composition\n// story in this package (e.g. dialog.stories.tsx) exposes its trigger, and\n// keeps the interaction a plain click.\nconst meta = {\n  component: Command,\n  subcomponents: {\n    CommandDialog,\n    CommandInput,\n    CommandList,\n    CommandEmpty,\n    CommandGroup,\n    CommandItem,\n    CommandSeparator,\n    CommandShortcut,\n  },\n  parameters: {\n    layout: \"centered\",\n  },\n  // Mirror the docs' ComponentPreview frame: center each example and\n  // width-constrain it to a single width, so the lead demo's own `max-w-sm`\n  // (stripped below) and the other inline examples all fill one frame\n  // instead of each picking its own size. AsDialog's Button trigger sits\n  // comfortably in the same frame; its portalled content is unaffected.\n  decorators: [\n    (Story) => (\n      <div className=\"w-[28rem] max-w-full\">\n        <Story />\n      </div>\n    ),\n  ],\n  tags: [\"autodocs\", \"shadcn-example\"],\n} satisfies Meta<typeof Command>;\n\nexport default meta;\n\ntype Story = StoryObj<typeof meta>;\n\n/**\n * Use as the default command menu — grouped suggestions and settings, a\n * disabled item, and keyboard shortcuts — filtered live as the user types.\n * The play function types a query and verifies matching items stay while\n * others are removed, then verifies the empty state for a query with no\n * match.\n *\n * Adapted from [shadcn Command demo](https://ui.shadcn.com/docs/components/radix/command)\n * (the default example at the top of the page, before any heading).\n *\n * @summary for the standard filterable command menu\n */\nexport const Basic: Story = {\n  render: () => (\n    <Command className=\"rounded-lg border\">\n      <CommandInput placeholder=\"Type a command or search...\" />\n      <CommandList>\n        <CommandEmpty>No results found.</CommandEmpty>\n        <CommandGroup heading=\"Suggestions\">\n          <CommandItem>\n            <CalendarIcon />\n            <span>Calendar</span>\n          </CommandItem>\n          <CommandItem>\n            <SmileIcon />\n            <span>Search Emoji</span>\n          </CommandItem>\n          <CommandItem disabled>\n            <CalculatorIcon />\n            <span>Calculator</span>\n          </CommandItem>\n        </CommandGroup>\n        <CommandSeparator />\n        <CommandGroup heading=\"Settings\">\n          <CommandItem>\n            <UserIcon />\n            <span>Profile</span>\n            <CommandShortcut>⌘P</CommandShortcut>\n          </CommandItem>\n          <CommandItem>\n            <CreditCardIcon />\n            <span>Billing</span>\n            <CommandShortcut>⌘B</CommandShortcut>\n          </CommandItem>\n          <CommandItem>\n            <SettingsIcon />\n            <span>Settings</span>\n            <CommandShortcut>⌘S</CommandShortcut>\n          </CommandItem>\n        </CommandGroup>\n      </CommandList>\n    </Command>\n  ),\n  play: async ({ canvas, userEvent }) => {\n    const input = canvas.getByRole(\"combobox\");\n\n    await userEvent.type(input, \"Emoji\");\n    await waitFor(() =>\n      expect(canvas.getByText(\"Search Emoji\")).toBeVisible(),\n    );\n    await expect(canvas.queryByText(\"Calendar\")).not.toBeInTheDocument();\n    await expect(canvas.queryByText(\"Billing\")).not.toBeInTheDocument();\n\n    await userEvent.clear(input);\n    await userEvent.type(input, \"doesnotexist\");\n    await waitFor(() =>\n      expect(canvas.getByText(\"No results found.\")).toBeVisible(),\n    );\n  },\n};\n\n/**\n * Use `CommandShortcut` beside an item's label to display its keyboard\n * shortcut — purely presentational, it doesn't bind the key itself.\n *\n * Adapted from [shadcn Command › Shortcuts](https://ui.shadcn.com/docs/components/radix/command#shortcuts)\n * (rendered as an inline panel rather than upstream's Button+CommandDialog\n * wrapper — see the file-level note on `Shortcuts`/`Scrollable`).\n *\n * @summary for items annotated with a keyboard shortcut\n */\nexport const Shortcuts: Story = {\n  render: () => (\n    <Command className=\"rounded-lg border\">\n      <CommandInput placeholder=\"Type a command or search...\" />\n      <CommandList>\n        <CommandEmpty>No results found.</CommandEmpty>\n        <CommandGroup heading=\"Settings\">\n          <CommandItem>\n            <UserIcon />\n            <span>Profile</span>\n            <CommandShortcut>⌘P</CommandShortcut>\n          </CommandItem>\n          <CommandItem>\n            <CreditCardIcon />\n            <span>Billing</span>\n            <CommandShortcut>⌘B</CommandShortcut>\n          </CommandItem>\n          <CommandItem>\n            <SettingsIcon />\n            <span>Settings</span>\n            <CommandShortcut>⌘S</CommandShortcut>\n          </CommandItem>\n        </CommandGroup>\n      </CommandList>\n    </Command>\n  ),\n  play: async ({ canvas }) => {\n    const profile = canvas.getByText(\"Profile\").closest('[cmdk-item=\"\"]');\n\n    await expect(profile).toHaveTextContent(\"⌘P\");\n    await expect(canvas.getByText(\"⌘B\")).toBeVisible();\n    await expect(canvas.getByText(\"⌘S\")).toBeVisible();\n  },\n};\n\nconst navigationItems = [\n  { label: \"Home\", shortcut: \"⌘H\" },\n  { label: \"Inbox\", shortcut: \"⌘I\" },\n  { label: \"Documents\", shortcut: \"⌘D\" },\n  { label: \"Folders\", shortcut: \"⌘F\" },\n];\n\nconst actionItems = [\n  { label: \"New File\", shortcut: \"⌘N\" },\n  { label: \"New Folder\", shortcut: \"⇧⌘N\" },\n  { label: \"Copy\", shortcut: \"⌘C\" },\n  { label: \"Cut\", shortcut: \"⌘X\" },\n  { label: \"Paste\", shortcut: \"⌘V\" },\n  { label: \"Delete\", shortcut: \"⌫\" },\n];\n\nconst viewItems = [\n  { label: \"Grid View\" },\n  { label: \"List View\" },\n  { label: \"Zoom In\", shortcut: \"⌘+\" },\n  { label: \"Zoom Out\", shortcut: \"⌘-\" },\n];\n\nconst accountItems = [\n  { label: \"Profile\", shortcut: \"⌘P\" },\n  { label: \"Billing\", shortcut: \"⌘B\" },\n  { label: \"Settings\", shortcut: \"⌘S\" },\n  { label: \"Notifications\" },\n  { label: \"Help & Support\" },\n];\n\nconst toolItems = [\n  { label: \"Calculator\" },\n  { label: \"Calendar\" },\n  { label: \"Image Editor\" },\n  { label: \"Code Editor\" },\n];\n\n/**\n * Use for a long, multi-group item list — the list viewport scrolls while\n * group headings stay attached to their items.\n *\n * Adapted from [shadcn Command › Scrollable](https://ui.shadcn.com/docs/components/radix/command#scrollable)\n * (rendered as an inline panel rather than upstream's Button+CommandDialog\n * wrapper — see the file-level note on `Shortcuts`/`Scrollable`).\n *\n * @summary for long, multi-group scrollable item lists\n */\nexport const Scrollable: Story = {\n  render: () => (\n    <Command className=\"rounded-lg border\">\n      <CommandInput placeholder=\"Type a command or search...\" />\n      <CommandList>\n        <CommandEmpty>No results found.</CommandEmpty>\n        <CommandGroup heading=\"Navigation\">\n          {navigationItems.map((item) => (\n            <CommandItem key={item.label}>\n              <span>{item.label}</span>\n              <CommandShortcut>{item.shortcut}</CommandShortcut>\n            </CommandItem>\n          ))}\n        </CommandGroup>\n        <CommandSeparator />\n        <CommandGroup heading=\"Actions\">\n          {actionItems.map((item) => (\n            <CommandItem key={item.label}>\n              <span>{item.label}</span>\n              <CommandShortcut>{item.shortcut}</CommandShortcut>\n            </CommandItem>\n          ))}\n        </CommandGroup>\n        <CommandSeparator />\n        <CommandGroup heading=\"View\">\n          {viewItems.map((item) => (\n            <CommandItem key={item.label}>\n              <span>{item.label}</span>\n              {item.shortcut && (\n                <CommandShortcut>{item.shortcut}</CommandShortcut>\n              )}\n            </CommandItem>\n          ))}\n        </CommandGroup>\n        <CommandSeparator />\n        <CommandGroup heading=\"Account\">\n          {accountItems.map((item) => (\n            <CommandItem key={item.label}>\n              <span>{item.label}</span>\n              {item.shortcut && (\n                <CommandShortcut>{item.shortcut}</CommandShortcut>\n              )}\n            </CommandItem>\n          ))}\n        </CommandGroup>\n        <CommandSeparator />\n        <CommandGroup heading=\"Tools\">\n          {toolItems.map((item) => (\n            <CommandItem key={item.label}>\n              <span>{item.label}</span>\n            </CommandItem>\n          ))}\n        </CommandGroup>\n      </CommandList>\n    </Command>\n  ),\n  play: async ({ canvas }) => {\n    await expect(canvas.getByText(\"Navigation\")).toBeInTheDocument();\n    await expect(canvas.getByText(\"Tools\")).toBeInTheDocument();\n    await expect(canvas.getByText(\"Help & Support\")).toBeVisible();\n  },\n};\n\nfunction CommandAsDialogDemo() {\n  const [open, setOpen] = React.useState(false);\n\n  return (\n    <>\n      <Button onClick={() => setOpen(true)} variant=\"outline\">\n        Open Command Palette\n      </Button>\n      <CommandDialog open={open} onOpenChange={setOpen}>\n        <CommandInput placeholder=\"Type a command or search...\" />\n        <CommandList>\n          <CommandEmpty>No results found.</CommandEmpty>\n          <CommandGroup heading=\"Suggestions\">\n            <CommandItem>\n              <CalendarIcon />\n              <span>Calendar</span>\n            </CommandItem>\n            <CommandItem>\n              <SmileIcon />\n              <span>Search Emoji</span>\n            </CommandItem>\n            <CommandItem>\n              <CalculatorIcon />\n              <span>Calculator</span>\n            </CommandItem>\n          </CommandGroup>\n          <CommandSeparator />\n          <CommandGroup heading=\"Settings\">\n            <CommandItem>\n              <UserIcon />\n              <span>Profile</span>\n              <CommandShortcut>⌘P</CommandShortcut>\n            </CommandItem>\n            <CommandItem>\n              <CreditCardIcon />\n              <span>Billing</span>\n              <CommandShortcut>⌘B</CommandShortcut>\n            </CommandItem>\n            <CommandItem>\n              <SettingsIcon />\n              <span>Settings</span>\n              <CommandShortcut>⌘S</CommandShortcut>\n            </CommandItem>\n          </CommandGroup>\n        </CommandList>\n      </CommandDialog>\n    </>\n  );\n}\n\n/**\n * Use `CommandDialog` to render the command list as an overlay palette\n * triggered from anywhere in the UI; the play function opens it from its\n * trigger and verifies the palette's list and an item appear.\n *\n * Adapted from [shadcn Command](https://ui.shadcn.com/docs/components/radix/command)\n * (`command-dialog.tsx`, a registered example not currently linked from a\n * docs heading — trigger changed from a global `⌘J` keydown listener to a\n * `Button`, see the file-level note).\n *\n * @summary for the command list rendered as an overlay palette\n */\nexport const AsDialog: Story = {\n  render: () => <CommandAsDialogDemo />,\n  play: async ({ canvas, userEvent }) => {\n    const trigger = canvas.getByRole(\"button\", {\n      name: \"Open Command Palette\",\n    });\n\n    await userEvent.click(trigger);\n    const dialog = await screen.findByRole(\"dialog\");\n    await waitFor(() =>\n      expect(screen.getByRole(\"listbox\")).toBeInTheDocument(),\n    );\n    await expect(dialog).toHaveTextContent(\"Calendar\");\n\n    await userEvent.keyboard(\"{Escape}\");\n    await waitFor(() =>\n      expect(screen.queryByRole(\"dialog\")).not.toBeInTheDocument(),\n    );\n    await expect(trigger).toHaveFocus();\n  },\n};\n",
