n\nexport const AccordionInCard: Story = {\n  render: () => (\n    <Card className=\"w-full max-w-sm\">\n      <CardHeader>\n        <CardTitle>Subscription & Billing</CardTitle>\n        <CardDescription>\n          Common questions about your account, plans, payments and\n          cancellations.\n        </CardDescription>\n      </CardHeader>\n      <CardContent>\n        <Accordion type=\"single\" collapsible defaultValue=\"plans\">\n          <AccordionItem value=\"plans\">\n            <AccordionTrigger>\n              What subscription plans do you offer?\n            </AccordionTrigger>\n            <AccordionContent>\n              We offer three subscription tiers.\n            </AccordionContent>\n          </AccordionItem>\n        </Accordion>\n      </CardContent>\n    </Card>\n  ),\n};\n\nfunction SelectAlignItemDemo() {\n  const alignItemWithTrigger = true;\n\n  return (\n    <FieldGroup className=\"w-full max-w-xs\">\n      <Field orientation=\"horizontal\">\n        <FieldContent>\n          <FieldLabel htmlFor=\"align-item\">Align Item</FieldLabel>\n          <FieldDescription>\n            Toggle to align the item with the trigger.\n          </FieldDescription>\n        </FieldContent>\n        <Switch id=\"align-item\" checked={alignItemWithTrigger} />\n      </Field>\n      <Field>\n        <Select defaultValue=\"banana\">\n          <SelectTrigger aria-label=\"Selected fruit\">\n            <SelectValue />\n          </SelectTrigger>\n          <SelectContent\n            aria-label=\"Fruit options\"\n            position={alignItemWithTrigger ? \"item-aligned\" : \"popper\"}\n          >\n            <SelectGroup>\n              <SelectItem value=\"apple\">Apple</SelectItem>\n              <SelectItem value=\"banana\">Banana</SelectItem>\n              <SelectItem value=\"blueberry\">Blueberry</SelectItem>\n              <SelectItem value=\"grapes\">Grapes</SelectItem>\n              <SelectItem value=\"pineapple\">Pineapple</SelectItem>\n 