{
  "$schema": "../../apps/api/src/instance-config/llame.config.schema.json",
  // E2E instance config (referenced via LLAME_CONFIG_PATH in
  // playwright.config.ts). Model selection is by opaque catalog id; the mock
  // model server answers any /chat/completions regardless of the provider
  // model id, so any valid catalog ids work here.
  "defaults": {
    "modelId": "system:openai:gpt-5.4-mini",
    "titleGenerationModelId": "system:openai:gpt-5.4-nano"
  },
  // Provider connection + executable catalog (providers-and-models-as-code,
  // #167): defaults.modelId/titleGenerationModelId above must reference a
  // models[].id or startup fails. key/baseUrl route to the mock model server
  // via the same OPENAI_API_KEY/OPENAI_BASE_URL env vars playwright.config.ts
  // already sets on the api webServer.
  "providers": [
    {
      "id": "mock",
      "type": "openai",
      "key": "{env:OPENAI_API_KEY:-}",
      "baseUrl": "{env:OPENAI_BASE_URL:-}"
    }
  ],
  "models": [
    {
      "id": "system:openai:gpt-5.4-mini",
      "provider": "mock",
      "providerModelId": "gpt-5.4-mini",
      "contextWindowTokens": 400000
    },
    {
      "id": "system:openai:gpt-5.4-nano",
      "provider": "mock",
      "providerModelId": "gpt-5.4-nano",
      "contextWindowTokens": 400000
    },
    {
      "id": "e2e:context-target-carmine",
      "provider": "mock",
      "providerModelId": "context-target-carmine",
      "name": "E2E Context Target",
      "systemPromptFile": "./prompts/context-target.md",
      "contextWindowTokens": 400000
    }
  ],
  // Tool-calling loop (openspec/changes/tool-calling-loop): the e2e tool-loop
  // browser suite (e2e/chat/tool-loop.spec.ts) drives search_conversations
  // through the mock model server — it must be allowlisted for those tests
  // to see any tool activity at all.
  "tools": {
    "allowed": ["search_conversations"]
  }
}
