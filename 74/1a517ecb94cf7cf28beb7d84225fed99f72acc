            "content": "import type { Meta, StoryObj } from \"@storybook/nextjs-vite\";\nimport { expect, screen, waitFor } from \"storybook/test\";\n\nimport { Button } from \"./button.js\";\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from \"./dialog.js\";\nimport { Field, FieldGroup, FieldLabel } from \"./field.js\";\nimport { Input } from \"./input.js\";\nimport { Label } from \"./label.js\";\nimport {\n  Popover,\n  PopoverContent,\n  PopoverDescription,\n  PopoverHeader,\n  PopoverTitle,\n  PopoverTrigger,\n} from \"./popover.js\";\n\n// This file is mixed provenance: `shadcn-example` (the meta default below)\n// for `Basic`, transcribed from the shadcn Popover docs' default top-of-page\n// demo (`popover-demo`, https://ui.shadcn.com/docs/components/radix/popover)\n// — the only Popover example that still has a `new-york-v4`-styled source\n// file. As of this writing every other example on that docs page — the\n// \"Basic\" section's own `popover-basic`, \"Align\"'s `popover-alignments`,\n// \"With Form\"'s `popover-form`, and RTL's `popover-rtl` — previews only\n// under the incompatible `radix-nova` style with no backing\n// `new-york-v4/examples/*.tsx` file (404). `WithForm`, `Alignments`, and\n// `InDialog` (each overrides the tag itself) keep our own `ai-generated`\n// coverage of those states instead of transcribing from the incompatible\n// registry. Upstream example we intentionally skip: RTL (excluded by\n// convention, and nova-only regardless).\nconst meta = {\n  component: Popover,\n  parameters: {\n    layout: \"centered\",\n  },\n  tags: [\"autodocs\", \"shadcn-example\"],\n} satisfies Meta<typeof Popover>;\n\nexport default meta;\n\ntype Story = StoryObj<typeof meta>;\n\n/**\n * Use for a click-triggered popup holding a small inline form; the play\n * function verifies the trigger toggles it open/closed and the field\n * defaults.\n *\n * Verbatim from [shadcn Popover](https://ui.shadcn.com/docs/components/radix/popover)\n * (the default example at the top of the page).\n *\n * @summary for the standard click-triggered form popover\n */\nexport const Basic: Story = {\n  render: () => (\n    <Popover>\n      <PopoverTrigger asChild>\n        <Button variant=\"outline\">Open popover</Button>\n      </PopoverTrigger>\n      <PopoverContent className=\"w-80\">\n        <div className=\"grid gap-4\">\n          <div className=\"space-y-2\">\n            <h4 className=\"leading-none font-medium\">Dimensions</h4>\n            <p className=\"text-sm text-muted-foreground\">\n              Set the dimensions for the layer.\n            </p>\n          </div>\n          <div className=\"grid gap-2\">\n            <div className=\"grid grid-cols-3 items-center gap-4\">\n              <Label htmlFor=\"width\">Width</Label>\n              <Input\n                id=\"width\"\n                defaultValue=\"100%\"\n                className=\"col-span-2 h-8\"\n              />\n            </div>\n            <div className=\"grid grid-cols-3 items-center gap-4\">\n              <Label htmlFor=\"maxWidth\">Max. width</Label>\n              <Input\n                id=\"maxWidth\"\n                defaultValue=\"300px\"\n                className=\"col-span-2 h-8\"\n              />\n            </div>\n            <div className=\"grid grid-cols-3 items-center gap-4\">\n              <Label htmlFor=\"height\">Height</Label>\n              <Input\n                id=\"height\"\n                defaultValue=\"25px\"\n                className=\"col-span-2 h-8\"\n              />\n            </div>\n            <div className=\"grid grid-cols-3 items-center gap-4\">\n              <Label htmlFor=\"maxHeight\">Max. height</Label>\n              <Input\n                id=\"maxHeight\"\n                defaultValue=\"none\"\n                className=\"col-span-2 h-8\"\n              />\n            </div>\n          </div>\n        </div>\n      </PopoverContent>\n    </Popover>\n  ),\n  play: async ({ canvas, userEvent }) => {\n    const trigger = canvas.getByRole(\"button\", { name: \"Open popover\" });\n\n    await userEvent.click(trigger);\n    await expect(await screen.findByText(\"Dimensions\")).toBeInTheDocument();\n    await expect(screen.getByLabelText(\"Width\")).toHaveValue(\"100%\");\n    await expect(screen.getByLabelText(\"Max. width\")).toHaveValue(\"300px\");\n    await expect(screen.getByLabelText(\"Height\")).toHaveValue(\"25px\");\n    await expect(screen.getByLabelText(\"Max. height\")).toHaveValue(\"none\");\n\n    await userEvent.click(trigger);\n    await waitFor(() =>\n      expect(screen.queryByText(\"Dimensions\")).not.toBeInTheDocument(),\n    );\n  },\n};\n\n/**\n * Use our `Field`/`FieldGroup` composition for small inline editing tasks\n * that don't warrant a full Dialog; fields are labelled via `FieldLabel`\n * `htmlFor`. Upstream's own \"With Form\" section\n * (https://ui.shadcn.com/docs/components/radix/popover#with-form) has no\n * `new-york-v4`-compatible source file, so this keeps our own coverage of a\n * form popover built from our Field primitives instead of transcribing from\n * the incompatible registry.\n *\n * @summary for inline mini-forms using our Field components\n */\nexport const WithForm: Story = {\n  tags: [\"ai-generated\", \"!shadcn-example\"],\n  render: () => (\n    <Popover>\n      <PopoverTrigger asChild>\n        <Button variant=\"outline\">Open Popover</Button>\n      </PopoverTrigger>\n      <PopoverContent aria-label=\"Dimensions\" className=\"w-64\" align=\"start\">\n        <PopoverHeader>\n          <PopoverTitle>Dimensions</PopoverTitle>\n          <PopoverDescription>\n            Set the dimensions for the layer.\n          </PopoverDescription>\n        </PopoverHeader>\n        <FieldGroup className=\"gap-4\">\n          <Field orientation=\"horizontal\">\n            <FieldLabel htmlFor=\"form-width\" className=\"w-1/2\">\n              Width\n  