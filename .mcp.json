{
  "mcpServers": {
    "next-devtools": {
      "command": "pnpx",
      "args": ["next-devtools-mcp@latest"]
    },
    "shadcn": {
      "command": "pnpx",
      "args": ["shadcn@latest", "mcp", "--cwd", "./packages/ui"]
    },
    "storybook": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    }
  }
}
