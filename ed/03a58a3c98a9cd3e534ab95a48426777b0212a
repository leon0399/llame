enai_key}\".\n//\n// Embedded (mid-string) tokens are only legal on string-typed settings, like\n// \"defaults.modelId\" below. Number/boolean settings must use a WHOLE-VALUE,\n// quoted token that gets coerced to the right type after resolution — never a\n// bare number with an embedded token, and never an unquoted token. See the\n// \"runs\" block below.\n{\n  \"$schema\": \"./llame.config.schema.json\",\n\n  // Instance-level model pointers — deliberately not under a \"models\" key,\n  // which is reserved for the future model-catalog list (providers-and-models-\n  // as-code follow-up). Falls back to DEFAULT_MODEL_ID / TITLE_GENERATION_MODEL_ID\n  // (see apps/api/.env.example) when absent here.\n  \"defaults\": {\n    \"modelId\": \"{env:DEFAULT_MODEL_ID:-system:openai:gpt-5.4-mini}\",\n    \"titleGenerationModelId\": \"{env:TITLE_GENERATION_MODEL_ID:-system:openai:gpt-5.4-nano}\"\n  },\n\n  // Run liveness (#48). Every setting here is a number, so an interpolated\n  // value must be a whole-value quoted token — the resolved string is coerced\n  // to a number after resolution; a non-numeric resolution fails the boot.\n  \"runs\": {\n    // Cap on a single run's generated output tokens. No legacy env var backs\n    // this one — set a literal, or a token if you'd rather drive it from the\n    // environment.\n    \"maxOutputTokens\": 4096,\n    // How often the executing worker stamps the run's heartbeat. Falls back to\n    // RUN_HEARTBEAT_SECONDS.\n    \"heartbeatSeconds\": \"{env:RUN_HEARTBEAT_SECONDS:-15}\",\n    // How stale a heartbeat may get before the deadman job expires the run.\n    // Falls back to RUN_HEARTBEAT_STALE_SECONDS.\n    \"heartbeatStaleSeconds\": \"{env:RUN_HEARTBEAT_STALE_SECONDS:-60}\",\n    // Deadman timeout after enqueue. Falls back to RUN_TIMEOUT_SECONDS.\n    \"timeoutSeconds\": \"{env:RUN_TIMEOUT_SECONDS:-300}\"\n  },\n\n  \"http\": {\n    // Reverse-proxy trust (#68) — falls back to TRUST_PROXY. Nullable:\n    //   - key ABSENT 