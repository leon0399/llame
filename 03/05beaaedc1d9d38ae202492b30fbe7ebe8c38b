           </SelectGroup>\n          </SelectContent>\n        </Select>\n      </Field>\n    </FieldGroup>\n  );\n}\n\nexport const SelectAlignItem: Story = {\n  render: () => <SelectAlignItemDemo />,\n};\n\nexport const SelectBasic: Story = {\n  render: () => (\n    <Select>\n      <SelectTrigger aria-label=\"Select a fruit\" className=\"w-full max-w-48\">\n        <SelectValue placeholder=\"Select a fruit\" />\n      </SelectTrigger>\n      <SelectContent aria-label=\"Fruit options\">\n        <SelectGroup>\n          <SelectLabel>Fruits</SelectLabel>\n          <SelectItem value=\"apple\">Apple</SelectItem>\n          <SelectItem value=\"banana\">Banana</SelectItem>\n          <SelectItem value=\"blueberry\">Blueberry</SelectItem>\n          <SelectItem value=\"grapes\">Grapes</SelectItem>\n          <SelectItem value=\"pineapple\">Pineapple</SelectItem>\n        </SelectGroup>\n      </SelectContent>\n    </Select>\n  ),\n};\n\nexport const SelectScrollable: Story = {\n  render: () => (\n    <Select>\n      <SelectTrigger aria-label=\"Select a timezone\" className=\"w-full max-w-64\">\n        <SelectValue placeholder=\"Select a timezone\" />\n      </SelectTrigger>\n      <SelectContent aria-label=\"Timezone options\">\n        <SelectGroup>\n          <SelectLabel>North America</SelectLabel>\n          <SelectItem value=\"est\">Eastern Standard Time</SelectItem>\n          <SelectItem value=\"cst\">Central Standard Time</SelectItem>\n        </SelectGroup>\n      </SelectContent>\n    </Select>\n  ),\n};\n",
