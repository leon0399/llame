            "content": "// One-off: capture every story via the real runner and approve each result,\n// writing committed baselines. Not part of the package — deleted after use.\nimport type { StoryIndex } from \"storybook/internal/types\";\n\nimport { VisualTestRunner } from \"./src/node/runner.js\";\nimport type { VisualResult } from \"./src/shared/results.js\";\n\nconst BASE = \"http://127.0.0.1:6006\";\nconst APPS_STORYBOOK = \"/home/leon0399/Projects/llame/apps/storybook\";\n\nlet cached: StoryIndex | undefined;\nconst storyIndexGenerator = {\n  async getIndex(): Promise<StoryIndex> {\n    cached ??= (await fetch(`${BASE}/index.json`).then((r) =>\n      r.json(),\n    )) as StoryIndex;\n    return cached;\n  },\n};\n\nconst runner = new VisualTestRunner({\n  baseUrl: BASE,\n  cwd: APPS_STORYBOOK,\n  storyRoots: [\"../../packages/ui/src\", \"../../apps/web\"],\n  storyIndexGenerator,\n});\n\nlet done = 0;\nrunner.setOnState((state) => {\n  const settled = state.results.filter(\n    (r) => r.status !== \"queued\" && r.status !== \"running\",\n  ).length;\n  if (settled !== done) {\n    done = settled;\n    if (done % 20 === 0)\n      process.stdout.write(`  …captured ${done}/${state.results.length}\\n`);\n  }\n});\n\nconsole.log(\"Capturing all stories (maxConcurrency 2)…\");\nconst state = await runner.run({ scope: \"all\" });\n\nconst counts: Record<string, number> = {};\nfor (const r of state.results) counts[r.status] = (counts[r.status] ?? 0) + 1;\nconsole.log(\"Capture summary:\", JSON.stringify(counts));\n\nconst toApprove = state.results.filter(\n  (r): r is VisualResult & { candidateSha256: string } =>\n    (r.status === \"new\" || r.status === \"changed\") &&\n    typeof r.candidateSha256 === \"string\",\n);\n\nlet approved = 0;\nconst approveFailures: Array<[string, string]> = [];\nfor (const r of toApprove) {\n  try {\n    await runner.approve({\n      runId: r.runId,\n      storyId: r.storyId,\n      environmentKey: r.environmentKey,\n      candidate